rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'alferasayman@gmail.com' && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helpers for specific data shapes
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string) &&
             (data.get('photoURL', '') is string);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'type', 'title', 'price']) &&
             data.id is string && data.id.size() <= 128 &&
             data.type in ['file', 'bundle'] &&
             data.title is string && data.title.size() <= 256 &&
             data.price is number && data.price >= 0;
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['productId', 'purchasedAt']) &&
             data.productId is string && data.productId.size() <= 128 &&
             data.purchasedAt == request.time;
    }

    function isValidExamResult(data) {
      return data.keys().hasAll(['subject', 'lesson', 'score', 'total', 'pct', 'createdAt']) &&
             data.subject is string && data.subject.size() <= 128 &&
             data.lesson is string && data.lesson.size() <= 256 &&
             data.score is number &&
             data.total is number &&
             data.pct is number &&
             data.createdAt == request.time;
    }

    function isValidLessonOverride(data) {
      return data.keys().hasAll(['id', 'questions']) &&
             data.id is string && data.id.size() <= 256 &&
             data.questions is list &&
             (data.get('lessonName', '') is string) &&
             (data.get('requiredProductId', '') is string);
    }

    // Phase 4: Match Blocks

    // Public Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    // Curriculum Overrides
    match /curriculum/{lessonId} {
      allow read: if true;
      allow write: if isAdmin() && isValidLessonOverride(incoming());
    }

    // User Private Data
    match /users/{userId} {
      // Profile isolation
      match /private/profile {
        allow get: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidUser(incoming()) && (
          // Identity Integrity
          incoming().uid == userId &&
          incoming().email == request.auth.token.email
        );
      }

      // Purchases
      match /purchases/{purchaseId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidPurchase(incoming());
        allow update, delete: if isAdmin(); // Users cannot modify their purchase history
      }

      // Exam History
      match /examHistory/{historyId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidExamResult(incoming());
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
